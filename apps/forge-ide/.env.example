# Forge / CreditChain staging defaults
FORGE_PUBLIC_URL=https://forge.creditchain.org
FORGE_API_URL=https://api.forge.creditchain.org
CREDITCHAIN_MAINNET_RPC_URL=https://rpc.creditchain.org
CREDITCHAIN_TESTNET_RPC_URL=https://testnet-rpc.creditchain.org
CREDITCHAIN_TESTNET_FAUCET_URL=https://faucet.creditchain.org
CREDITCHAIN_EXPLORER_URL=https://scan.creditchain.org
CREDITCHAIN_TESTNET_EXPLORER_URL=https://testnet-scan.creditchain.org
