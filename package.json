{
  "name": "forge",
  "version": "2.3.0-dev",
  "license": "MIT",
  "description": "Forge: AI-native CreditChain smart contract studio forked from Ethereum Remix",
  "main": "index.js",
  "defaultVersion": "soljson-v0.8.34+commit.80d5c536.js",
  "keywords": [
    "creditchain",
    "forge",
    "creditforge",
    "evm",
    "ethereum",
    "solidity",
    "compiler"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openibank/forge.git"
  },
  "author": "OpeniBank / CreditChain",
  "bugs": {
    "url": "https://github.com/openibank/forge/issues"
  },
  "homepage": "https://forge.creditchain.org",
  "bin": {
    "forge-ide": "./apps/forge-ide/bin/forge-ide"
  },
  "engines": {
    "npm": "^6.14.15"
  },
  "scripts": {
    "nx": "nx",
    "start": "nx start",
    "serve": "node --max-old-space-size=8192 ./node_modules/.bin/nx serve forge-ide --configuration=development --memoryLimit=6144",
    "serve:hot": "node --max-old-space-size=8192 ./node_modules/.bin/nx serve forge-ide --configuration=hot",
    "serve:endpoints": "NX_ENDPOINTS_URL=\"http://localhost\" yarn serve",
    "serve:ngrok": "ngrok http 8080 --domain=remix-dev.ngrok.dev",
    "serve:plugin": "nx serve ${npm_config_plugin} --configuration=development",
    "build:plugin": "NODE_ENV=production nx build ${npm_config_plugin} --configuration=production",
    "build": "node --max-old-space-size=4096 ./node_modules/.bin/nx build || node --max-old-space-size=4096 ./node_modules/.bin/nx build --skip-nx-cache",
    "test": "nx test",
    "lint": "nx lint",
    "lint-fix": "node ./apps/forge-ide/ci/lint-targets-fix.js",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "affected:build": "nx affected:build",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "affected:dep-graph": "nx affected:dep-graph",
    "affected": "nx affected",
    "format": "nx format:write",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "update": "nx migrate latest",
    "workspace-schematic": "nx workspace-schematic",
    "dep-graph": "nx dep-graph",
    "help": "nx help",
    "lint-entire": "prettier --write {apps,libs}/**/*.{js,ts,tsx}",
    "lint:libs": "nx run-many --target=lint --projects=forge-analyzer,forge-astwalker,forge-debug,forge-lib,forge-simulator,forge-solidity,forge-tests,forge-url-resolver,forge-ws-templates,forged,forge-core-plugin,forge-import-resolver,forge-ui,ghaction-helper,forge-ai-core,forge-creditchain-config",
    "build:libs": "node --max-old-space-size=4096 ./node_modules/.bin/nx run-many --target=build --parallel=false --with-deps=true --projects=forge-analyzer,forge-astwalker,forge-debug,forge-lib,forge-simulator,forge-solidity,forge-tests,forge-url-resolver,forge-ws-templates,forged,ghaction-helper,forge-import-resolver,forge-ai-core,forge-creditchain-config",
    "test:libs": "nx run-many --target=test --projects=forge-analyzer,forge-astwalker,forge-debug,forge-lib,forge-simulator,forge-tests,forge-url-resolver,forge-import-resolver",
    "publish:forged": "bash scripts/publish-forged.sh",
    "publish:remixd": "yarn publish:forged",
    "publish:libs": "yarn run build:libs && lerna publish --no-verify-access --skip-git && yarn run bumpVersion:libs",
    "publishDev:libs": "yarn run build:libs && lerna publish --npm-tag alpha --skip-git && yarn run bumpVersion:libs",
    "build:e2e": "node apps/forge-ide-e2e/src/cleanupGroupTests.js && node apps/forge-ide-e2e/src/buildGroupTests.js && tsc -p apps/forge-ide-e2e/tsconfig.e2e.json && node scripts/update-e2e-keywords.js",
    "inject-e2e-config": "node scripts/inject-e2e-config.js dist/apps/forge-ide \"http://127.0.0.1:8080/assets/js/soljson\" \"http://127.0.0.1:8080/assets/js/soljson\" \"http://127.0.0.1:9090/\"",
    "build:desktop": "rm -rf apps/forge-desktop/build/forge-ide && mkdir -p apps/forge-desktop/build && NX_DESKTOP_FROM_DIST=true node --max-old-space-size=8192 ./node_modules/.bin/nx build forge-ide --configuration=desktop && cp -r dist/apps/forge-ide apps/forge-desktop/build/forge-ide",
    "build:desktopwin": "cross-env NX_DESKTOP_FROM_DIST=true bash -c \"rm -rf apps/forge-desktop/build/forge-ide && mkdir -p apps/forge-desktop/build && node --max-old-space-size=8192 ./node_modules/.bin/nx build forge-ide --configuration=desktop && cp -r dist/apps/forge-ide apps/forge-desktop/build/forge-ide\"",
    "babel": "babel",
    "watch:e2e": "nodemon",
    "bumpVersion:forged": "gulp syncForgedVersion",
    "bumpVersion:remixd": "yarn bumpVersion:forged;",
    "bumpVersion:libs": "gulp & gulp syncLibVersions;",
    "updateBeta": "gulp & gulp updateBetaToMaster;",
    "updateLive": "gulp & gulp updateLiveToBeta;",
    "publishTagfromBeta": "gulp & gulp publishTagfromBeta;",
    "createPRToBeta": "npx ts-node createPRToBeta.ts",
    "browsertest": "sleep 5 && yarn run nightwatch_local",
    "csslint": "csslint --ignore=order-alphabetical --errors='errors,duplicate-properties,empty-rules' --exclude-list='apps/forge-ide/src/assets/css/font-awesome.min.css' apps/forge-ide/src/assets/css/",
    "downloadsolc_assets_e2e": "node ./apps/forge-ide/ci/download_e2e_assets.js",
    "make-mock-compiler": "node apps/forge-ide/ci/makeMockCompiler.js",
    "minify": "uglifyjs --in-source-map inline --source-map-inline -c warnings=false",
    "build:production": "NX_NO_CLOUD=true NX_DAEMON=false NX_PARALLEL=2 MINIFIER_PARALLEL=2 NODE_ENV=production node --max-old-space-size=8192 ./node_modules/.bin/nx build forge-ide --configuration=production --skip-nx-cache --verbose",
    "deploy:forge:pages": "bash scripts/deploy-forge-github-pages.sh",
    "deploy:forge:maple": "bash scripts/deploy-forge-maple.sh",
    "dns:forge": "bash scripts/route53-upsert-forge-suite.sh",
    "pages:forge:status": "bash scripts/check-forge-pages-status.sh",
    "pages:forge:enable-https": "bash scripts/enable-forge-pages-https-once.sh",
    "serve:production": "npx http-server ./dist/apps/forge-ide",
    "install_webdriver": "bash ./apps/forge-ide-e2e/install-webdriver.sh",
    "update_metamask": "bash ./apps/forge-ide-e2e/update_metamask.sh",
    "select_test": "dotenv -e .env.local -- bash apps/forge-ide-e2e/src/select_tests.sh",
    "onchange": "onchange apps/forge-ide/build/app.js -- npm-run-all lint",
    "forged": "nx build forged && chmod +x dist/libs/forged/src/bin/forged.js dist/libs/forged/src/bin/remixd.js && dist/libs/forged/src/bin/forged.js --forge-ide http://127.0.0.1:8080",
    "remixd": "yarn forged",
    "simulator": "nx build forge-simulator && chmod +x dist/libs/forge-simulator/bin/ethsim && dist/libs/forge-simulator/bin/ethsim start --rpc",
    "sourcemap": "exorcist --root ../ apps/forge-ide/build/app.js.map > apps/forge-ide/build/app.js",
    "watch": "watchify apps/forge-ide/src/index.js -dv -p browserify-reload -o apps/forge-ide/build/app.js --exclude solc",
    "reinstall": "rm ./node-modules/ -rf && rm yarn.lock && rm ./build/ -rf && yarn install & yarn run build",
    "ganache": "npx ganache",
    "build-contracts": "find ./node_modules/@openzeppelin/contracts | grep -i '.sol' > libs/forge-ui/editor/src/lib/providers/completion/contracts/contracts.txt && find ./node_modules/@uniswap/v3-core/contracts | grep -i '.sol' >> libs/forge-ui/editor/src/lib/providers/completion/contracts/contracts.txt",
    "playwright:record": "playwright codegen http://127.0.0.1:8080 --target=playwright-test -o tests/recorded.spec.ts",
    "test:e2e": "bash apps/forge-ide-e2e/run-test.sh",
    "ci:timings": "node scripts/circleci-timings.js",
    "ci:plan-shard": "node scripts/plan-shards.js",
    "ci:failed-report": "node scripts/generate-failed-report.js --workflow web --out reports/ci-latest-failed",
    "ci:post-pr-report": "node scripts/post-pr-report.js reports/ci-latest-failed",
    "update:e2e-keywords": "node scripts/update-e2e-keywords.js"
  },
